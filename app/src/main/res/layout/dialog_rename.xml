<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/rename_title"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/paper"
        android:letterSpacing="0.2" />

    <TextView
        android:id="@+id/rename_current"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textColor="@color/paper_dim"
        android:letterSpacing="0.1"
        android:layout_marginTop="6dp"
        tools:text="DIRECT-go-CFMOTO-244E67" />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/rename_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_edit"
        android:padding="12dp"
        android:textSize="15sp"
        android:textColor="@color/paper"
        android:textColorHint="@color/paper_faint"
        android:hint="@string/rename_hint"
        android:singleLine="true"
        android:imeOptions="actionDone"
        android:inputType="text"
        android:maxLength="24" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="18dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_rename_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/OCF.GhostButton.Small"
            android:text="@string/btn_cancel"
            android:layout_marginEnd="10dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_rename_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/OCF.GhostButton.Small"
            android:text="@string/btn_save" />
    </LinearLayout>
</LinearLayout>
