<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:id="@+id/qr_frame"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_panel" />

    <TextView
        android:id="@+id/hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/scrim"
        android:padding="16dp"
        android:text="@string/qr_hint"
        android:textAlignment="center"
        android:textColor="@color/paper"
        android:fontFamily="@font/app_mono"
        android:textSize="12sp"
        android:letterSpacing="0.1"
        android:textAllCaps="true" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="64dp"
        android:background="@color/scrim"
        android:orientation="horizontal"
        android:padding="8dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_zoom_1x"
            android:layout_width="56dp"
            android:layout_height="40dp"
            android:layout_marginEnd="4dp"
            android:minWidth="0dp"
            android:padding="0dp"
            style="@style/OCF.GhostButton.Small"
            android:text="1x" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_zoom_2x"
            android:layout_width="56dp"
            android:layout_height="40dp"
            android:layout_marginEnd="4dp"
            android:minWidth="0dp"
            android:padding="0dp"
            style="@style/OCF.GhostButton.Small"
            android:text="2x" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_zoom_3x"
            android:layout_width="56dp"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:padding="0dp"
            style="@style/OCF.GhostButton.Small"
            android:text="3x" />
    </LinearLayout>
</FrameLayout>
